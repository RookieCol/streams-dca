# Network the bot operates on: "celo" (mainnet) or "celoSepolia"
CHAIN=celo
RPC_URL=https://forno.celo.org

# Bot key. Must match the address configured as `bot` in StreamVaultsConfig.
BOT_PRIVATE_KEY=0x...

# Deployed StreamVaults gateway address (from apps/contracts/script/Deploy.s.sol output).
STREAM_VAULTS_ADDRESS=0x...

# How often the bot polls for due streams, in milliseconds.
POLL_INTERVAL_MS=90000

# ERC-8021 attribution code obtained by registering the project at
# https://celobuilders.xyz (npx skills add https://celobuilders.xyz). Leave unset
# to run the bot without attribution tagging.
ATTRIBUTION_CODE=

# Uniswap v3 fee tier for the USDT->WBTC pool (0.3% = 3000).
SWAP_FEE_TIER=3000

# --- used only by scripts/register-agent.ts ---
# Public URL of the agent metadata JSON (e.g. https://<your-web-deployment>/agent.json)
AGENT_METADATA_URI=
